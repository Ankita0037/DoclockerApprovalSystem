@using DocLocker.Web.Models
@model ManagerProjectsViewModel

@{
    ViewData["Title"] = "My Projects";
}

<div class="container-fluid mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white">
            <div class="row align-items-center">
                <div class="col">
                    <h5 class="mb-0">
                        <i class="bi bi-list me-2"></i>Project List
                    </h5>
                </div>
                <div class="col-auto">
                    <span class="badge bg-light text-dark">@Model.Projects.Count Projects</span>
                </div>
            </div>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Project</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Projects.Count == 0)
                        {
                            <tr>
                                <td colspan="3" class="text-center text-muted py-4">
                                    <i class="bi bi-inbox me-2"></i>No projects assigned yet.
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var projectEntry in Model.Projects)
                            {
                                <tr>
                                    <td>@projectEntry.Project.Name</td>
                                    <td>@projectEntry.Project.Status</td>
                                    <td class="d-flex flex-wrap gap-2">
                                        <button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#manageMembersModal-@projectEntry.Project.ProjectId">
                                            Manage Members
                                        </button>
                                        <button class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#createRequestModal-@projectEntry.Project.ProjectId">
                                            Create Request
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@foreach (var projectEntry in Model.Projects)
{
    <div class="modal fade" id="manageMembersModal-@projectEntry.Project.ProjectId" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Manage Members - @projectEntry.Project.Name</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <form asp-action="AddMember" method="post" class="row g-3">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="projectId" value="@projectEntry.Project.ProjectId" />
                        <div class="col-12">
                            <label class="form-label">Add Member</label>
                            <div class="d-flex gap-2">
                                <select class="form-select" name="memberId" required>
                                    <option value="">Select member</option>
                                    @foreach (var member in projectEntry.AvailableMembers)
                                    {
                                        <option value="@member.UserId">@member.Name (@member.Email)</option>
                                    }
                                </select>
                                <button type="submit" class="btn btn-primary">Add</button>
                            </div>
                        </div>
                    </form>

                    <hr />

                    <h6 class="mb-3">Assigned Members</h6>
                    @if (projectEntry.AssignedMembers.Count == 0)
                    {
                        <div class="text-muted">No members assigned yet.</div>
                    }
                    else
                    {
                        <ul class="list-group">
                            @foreach (var member in projectEntry.AssignedMembers)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    <div>
                                        <div>@member.Name</div>
                                        <small class="text-muted">@member.Email</small>
                                    </div>
                                    <form asp-action="RemoveMember" method="post" class="ms-3">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="projectId" value="@projectEntry.Project.ProjectId" />
                                        <input type="hidden" name="memberId" value="@member.UserId" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger">Remove</button>
                                    </form>
                                </li>
                            }
                        </ul>
                    }

                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="createRequestModal-@projectEntry.Project.ProjectId" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Create Request - @projectEntry.Project.Name</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <!-- This modal only handles creating a document request. -->
                    @if (projectEntry.AssignedMembers.Count == 0)
                    {
                        <div class="text-muted">Assign a member before creating a document request.</div>
                    }
                    else
                    {
                        <form asp-action="CreateDocumentRequest" method="post" class="row g-3">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="ProjectId" value="@projectEntry.Project.ProjectId" />
                            <div class="col-12">
                                <label class="form-label">Member</label>
                                <select class="form-select" name="MemberId" required>
                                    <option value="">Select member</option>
                                    @foreach (var member in projectEntry.AssignedMembers)
                                    {
                                        <option value="@member.UserId">@member.Name (@member.Email)</option>
                                    }
                                </select>
                            </div>
                            <div class="col-12">
                                <label class="form-label">Title</label>
                                <input class="form-control" name="Title" maxlength="200" required />
                            </div>
                            <div class="col-12">
                                <label class="form-label">Description</label>
                                <textarea class="form-control" name="Description" rows="3" maxlength="1000"></textarea>
                            </div>
                            <div class="col-12">
                                <label class="form-label">Due Date</label>
                                <input class="form-control" type="date" name="DueDate" />
                            </div>
                            <div class="col-12 d-flex justify-content-end">
                                <button type="submit" class="btn btn-primary">Create Request</button>
                            </div>
                        </form>
                    }
                </div>
            </div>
        </div>
    </div>
}
