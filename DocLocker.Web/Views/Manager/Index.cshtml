@{
    ViewData["Title"] = "Manager Dashboard";
}

<div class="container-fluid">
    <h2 class="mb-4 fw-bold">
        <i class="bi bi-speedometer2 me-2"></i>Manager Dashboard
    </h2>

    <!-- Stats Row -->
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card shadow-sm border-0">
                <div class="card-body text-center">
                    <i class="bi bi-hourglass-split" style="font-size: 2rem; color: #ffc107;"></i>
                    <h5 class="mt-3">Pending</h5>
                    <h2 class="text-warning">0</h2>
                    <small class="text-muted">Awaiting your approval</small>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm border-0">
                <div class="card-body text-center">
                    <i class="bi bi-check-circle" style="font-size: 2rem; color: #28a745;"></i>
                    <h5 class="mt-3">Approved</h5>
                    <h2 class="text-success">0</h2>
                    <small class="text-muted">Approved by you</small>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm border-0">
                <div class="card-body text-center">
                    <i class="bi bi-x-circle" style="font-size: 2rem; color: #dc3545;"></i>
                    <h5 class="mt-3">Rejected</h5>
                    <h2 class="text-danger">0</h2>
                    <small class="text-muted">Rejected by you</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="row">
        <div class="col-md-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-warning text-dark">
                    <h5 class="mb-0">
                        <i class="bi bi-lightning me-2"></i>Quick Actions
                    </h5>
                </div>
                <div class="card-body">
                    <a href="/Manager/Pending" class="btn btn-warning w-100 mb-2">
                        <i class="bi bi-clock-history me-2"></i>View Pending Approvals
                    </a>
                    <a href="#" class="btn btn-outline-warning w-100">
                        <i class="bi bi-archive me-2"></i>View History
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0">
                        <i class="bi bi-info-circle me-2"></i>Your Info
                    </h5>
                </div>
                <div class="card-body">
                    <p class="mb-2">
                        <strong>Role:</strong> Approval Manager
                    </p>
                    <p class="mb-2">
                        <strong>Department:</strong> Quality Assurance
                    </p>
                    <p class="mb-0">
                        <strong>Status:</strong> <span class="badge bg-success">Active</span>
                    </p>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Approvals -->
    <div class="row mt-4">
        <div class="col-12">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-secondary text-white">
                    <h5 class="mb-0">
                        <i class="bi bi-file-earmark me-2"></i>Recent Approvals
                    </h5>
                </div>
                <div class="card-body">
                    <div class="text-center text-muted py-4">
                        <i class="bi bi-inbox" style="font-size: 2rem;"></i>
                        <p class="mt-2">No recent approvals. Check pending approvals to get started!</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
