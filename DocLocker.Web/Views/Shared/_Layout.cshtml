<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Document Approval Workflow System</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/DocLocker.Web.styles.css" asp-append-version="true" />
</head>
<body>

    @{
        var role = Context.Session.GetString("Role");
    }

    <!-- ✅ NAVBAR -->
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-light shadow-sm sticky-top">
            <div class="container-lg">

                <a class="navbar-brand fw-bold d-flex align-items-center" asp-controller="Home" asp-action="Index">
                    <img src="~/images/DocLockerLogo.png" class="logo-img me-2">
                    <span class="d-none d-sm-inline">DocLocker</span>
                </a>

                <div class="navbar-collapse collapse">
                    <ul class="navbar-nav ms-auto">

                        @if (string.IsNullOrEmpty(role))
                        {
                            <!-- BEFORE LOGIN -->
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="#features">Features</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="#working">How It Works?</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link btn btn-outline-primary btn-sm ms-2"
                                   asp-controller="Account" asp-action="Login">Login</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link btn btn-primary btn-sm ms-2 text-white"
                                   asp-controller="Account" asp-action="Register">Register</a>
                            </li>
                        }
                        else
                        {
                            <!-- AFTER LOGIN -->
                            <li class="nav-item me-3 mt-2">
                                <span class="fw-bold text-primary">@role</span>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-danger btn-sm"
                                       asp-controller="Account"
                                       asp-action="Logout">
                                    Logout
                                </a>
                            </li>
                        }

                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <!-- ✅ AFTER LOGIN → SIDEBAR + CONTENT -->
    @if (!string.IsNullOrEmpty(role))
    {
        <div class="d-flex">

            <!-- Sidebar Partial -->
            <partial name="_Sidebar" />

            <!-- Main Content -->
            <div class="flex-grow-1 p-4">
                @RenderBody()
            </div>

        </div>
    }
    else
    {
        <!-- BEFORE LOGIN → NORMAL PAGE -->
        <main role="main">
            @RenderBody()
        </main>
    }

    <!-- ✅ FOOTER -->
    <footer class="bg-dark text-light mt-5 py-4">
        <div class="container-lg text-center">
            <small>&copy; 2026 DocLocker. All rights reserved.</small>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>

<partial name="_ValidationScriptsPartial" />