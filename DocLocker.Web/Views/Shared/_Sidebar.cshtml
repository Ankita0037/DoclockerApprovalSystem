@{
    var currentAction = ViewContext.RouteData.Values["Action"]?.ToString() ?? "";
    var currentController = ViewContext.RouteData.Values["Controller"]?.ToString() ?? "";
}

<aside class="bg-dark text-white p-0" style="width: 250px; min-height: 100vh; box-shadow: 2px 0 5px rgba(0,0,0,0.1);">
    <div class="p-3 border-bottom">
        <h5 class="mb-0 d-flex align-items-center">
            <i class="bi bi-file-lock2 me-2"></i>
            <span>DocLocker</span>
        </h5>
    </div>

    <nav class="nav flex-column p-3">
        @if (Context.Session.GetString("Role") == "User")
        {
            <a href="/User/Index" class="nav-link text-white @(currentAction == "Index" && currentController == "User" ? "active bg-primary" : "") mb-2">
                <i class="bi bi-house me-2"></i>Dashboard
            </a>
            <a href="/User/Upload" class="nav-link text-white @(currentAction == "Upload" && currentController == "User" ? "active bg-primary" : "") mb-2">
                <i class="bi bi-cloud-arrow-up me-2"></i>Upload Document
            </a>
            <a href="/User/MyDocuments" class="nav-link text-white @(currentAction == "MyDocuments" && currentController == "User" ? "active bg-primary" : "") mb-2">
                <i class="bi bi-file-earmark me-2"></i>My Documents
            </a>
        }

        @if (Context.Session.GetString("Role") == "Manager")
        {
            <a href="/Manager/Index" class="nav-link text-white @(currentAction == "Index" && currentController == "Manager" ? "active bg-primary" : "") mb-2">
                <i class="bi bi-house me-2"></i>Dashboard
            </a>
            <a href="/Manager/Pending" class="nav-link text-white @(currentAction == "Pending" && currentController == "Manager" ? "active bg-primary" : "") mb-2">
                <i class="bi bi-clock-history me-2"></i>Pending Approvals
            </a>
        }

        @if (Context.Session.GetString("Role") == "Admin")
        {
            <a href="/Admin/Index" class="nav-link text-white @(currentAction == "Index" && currentController == "Admin" ? "active bg-primary" : "") mb-2">
                <i class="bi bi-house me-2"></i>Dashboard
            </a>
            <a href="/Admin/Users" class="nav-link text-white @(currentAction == "Users" && currentController == "Admin" ? "active bg-primary" : "") mb-2">
                <i class="bi bi-people me-2"></i>Users
            </a>
        }
    </nav>

    <div class="p-3 border-top mt-auto">
        <small class="text-muted d-block">
            <i class="bi bi-person-circle me-1"></i>
            Logged in as: @Context.Session.GetString("Role")
        </small>
    </div>
</aside>