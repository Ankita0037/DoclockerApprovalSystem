@{
    var currentAction = ViewContext.RouteData.Values["Action"]?.ToString() ?? "";
    var currentController = ViewContext.RouteData.Values["Controller"]?.ToString() ?? "";
    var statusFilter = Context.Request.Query["status"].ToString() ?? "";
    var isAssignmentStatusActive = currentAction == "MyDocuments" && currentController == "User" && !string.IsNullOrWhiteSpace(statusFilter);
}

<aside class="sidebar-nav p-0">

    <nav class="nav flex-column p-3">
        @if (Context.Session.GetString("Role") == "User")
        {
            <a href="/User/Index" class="sidebar-nav-link @(currentAction == "Index" && currentController == "User" ? "active" : "") mb-2">
                <i class="bi bi-house me-2"></i>Dashboard
            </a>
            <a href="/User/Upload" class="sidebar-nav-link @(currentAction == "Upload" && currentController == "User" ? "active" : "") mb-2">
                <i class="bi bi-cloud-arrow-up me-2"></i>Upload Document
            </a>
            <a href="/User/MyDocuments" class="sidebar-nav-link @(currentAction == "MyDocuments" && currentController == "User" ? "active" : "") mb-2">
                <i class="bi bi-file-earmark me-2"></i>My Documents
            </a>
            <a class="sidebar-nav-link mb-2 d-flex justify-content-between align-items-center"
               data-bs-toggle="collapse"
               href="#assignmentStatusMenu"
               role="button"
               aria-expanded="@(isAssignmentStatusActive.ToString().ToLowerInvariant())"
               aria-controls="assignmentStatusMenu">
                <span><i class="bi bi-clipboard-check me-2"></i>Assignment Status</span>
                <i class="bi bi-chevron-down small"></i>
            </a>
            <div class="collapse @(isAssignmentStatusActive ? "show" : "")" id="assignmentStatusMenu">
                <a href="/User/MyDocuments?status=Draft" class="sidebar-nav-link ps-4 @(currentAction == "MyDocuments" && currentController == "User" && statusFilter == "Draft" ? "active" : "") mb-2">
                    Draft
                </a>
                <a href="/User/MyDocuments?status=Unassigned" class="sidebar-nav-link ps-4 @(currentAction == "MyDocuments" && currentController == "User" && statusFilter == "Unassigned" ? "active" : "") mb-2">
                    Unassigned
                </a>
                <a href="/User/MyDocuments?status=Pending" class="sidebar-nav-link ps-4 @(currentAction == "MyDocuments" && currentController == "User" && statusFilter == "Pending" ? "active" : "") mb-2">
                    Pending
                </a>
                <a href="/User/MyDocuments?status=RevisionRequested" class="sidebar-nav-link ps-4 @(currentAction == "MyDocuments" && currentController == "User" && statusFilter == "RevisionRequested" ? "active" : "") mb-2">
                    Revision Requested
                </a>
                <a href="/User/MyDocuments?status=Approved" class="sidebar-nav-link ps-4 @(currentAction == "MyDocuments" && currentController == "User" && statusFilter == "Approved" ? "active" : "") mb-2">
                    Approved
                </a>
                <a href="/User/MyDocuments?status=Rejected" class="sidebar-nav-link ps-4 @(currentAction == "MyDocuments" && currentController == "User" && statusFilter == "Rejected" ? "active" : "") mb-2">
                    Rejected
                </a>
            </div>
        }

        @if (Context.Session.GetString("Role") == "Manager")
        {
            <a href="/Manager/Index" class="sidebar-nav-link @(currentAction == "Index" && currentController == "Manager" ? "active" : "") mb-2">
                <i class="bi bi-house me-2"></i>Dashboard
            </a>
            <a href="/Manager/Pending" class="sidebar-nav-link @(currentAction == "Pending" && currentController == "Manager" ? "active" : "") mb-2">
                <i class="bi bi-clock-history me-2"></i>Pending Approvals
            </a>
        }

        @if (Context.Session.GetString("Role") == "Admin")
        {
            <div class="sidebar-section">
                <div class="sidebar-section-title">Main</div>
                <a href="/Admin/Index" class="sidebar-nav-link @(currentAction == "Index" && currentController == "Admin" ? "active" : "") mb-2">
                    <i class="bi bi-speedometer2 me-2"></i>Dashboard
                </a>
            </div>
            <div class="sidebar-section">
                <div class="sidebar-section-title">Management</div>
                <a href="/Admin/Users" class="sidebar-nav-link @(currentAction == "Users" && currentController == "Admin" ? "active" : "") mb-2">
                    <i class="bi bi-people me-2"></i>Users
                </a>
                <a href="/Admin/Projects" class="sidebar-nav-link @(currentAction == "Projects" && currentController == "Admin" ? "active" : "") mb-2">
                    <i class="bi bi-folder2-open me-2"></i>Projects
                </a>
            </div>
            <div class="sidebar-section">
                <div class="sidebar-section-title">Workflow</div>
                <a href="/Admin/Requests" class="sidebar-nav-link @(currentAction == "Requests" && currentController == "Admin" ? "active" : "") mb-2">
                    <i class="bi bi-inbox me-2"></i>Requests
                </a>
                <a href="/Admin/Reports" class="sidebar-nav-link @(currentAction == "Reports" && currentController == "Admin" ? "active" : "") mb-2">
                    <i class="bi bi-bar-chart-line me-2"></i>Reports
                </a>
            </div>
            <div class="sidebar-section">  
                <a href="/Admin/Settings" class="sidebar-nav-link @(currentAction == "Settings" && currentController == "Admin" ? "active" : "") mb-2">
                    <i class="bi bi-gear me-2"></i>Settings
                </a>
            </div>
        }
    </nav>

    <div class="sidebar-user p-3 mt-auto">
        <small class="d-block">
            <i class="bi bi-person-circle me-1"></i>
            Logged in as: @Context.Session.GetString("Role")
        </small>
    </div>
</aside>
