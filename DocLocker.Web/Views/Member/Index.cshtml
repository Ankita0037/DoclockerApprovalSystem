@{
    ViewData["Title"] = "Member Dashboard";
}

<div class="container-fluid">
    <h2 class="mb-4 fw-bold">
        <i class="bi bi-speedometer2 me-2"></i>Dashboard
    </h2>

    <div class="row mb-4">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">
                        <i class="bi bi-inbox me-2"></i>Assigned Requests
                    </h5>
                </div>
                <div class="card-body">
                    <p class="text-muted mb-4">
                        View document requests assigned to you by your manager and check which ones are pending or need revision.
                    </p>
                    <a href="/Member/Requests" class="btn btn-primary">
                        <i class="bi bi-list-check me-2"></i>Open My Requests
                    </a>
                </div>
            </div>
        </div>

        <div class="col-lg-4 mt-3 mt-lg-0">
            <div class="card shadow-sm border-0">
                <div class="card-header text-dark">
                    <h5 class="mb-0">
                        <i class="bi bi-info-circle me-2"></i>Current Flow
                    </h5>
                </div>
                <div class="card-body">
                    <ol class="mb-0">
                        <li>Manager assigns a document request.</li>
                        <li>You review the request details.</li>
                        <li>Upload is available only from eligible requests.</li>
                        <li>Status updates appear against the request.</li>
                    </ol>
                </div>
            </div>
        </div>
    </div>
</div>
