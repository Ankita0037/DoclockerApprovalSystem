@{
    ViewData["Title"] = "My Documents";
}

<div class="container-fluid">
    <h2 class="mb-4 fw-bold">
        <i class="bi bi-file-earmark me-2"></i>My Documents
    </h2>

    <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white">
            <div class="row align-items-center">
                <div class="col">
                    <h5 class="mb-0">
                        <i class="bi bi-list me-2"></i>Document List
                    </h5>
                </div>
                <div class="col-auto">
                    <a href="/Member/Upload" class="btn btn-sm btn-light">
                        <i class="bi bi-plus-circle me-1"></i>Upload New
                    </a>
                </div>
            </div>
        </div>
        <div class="card-body">
            <!-- Filter and Search -->
            <div class="row mb-4">
                <div class="col-md-6">
                    <div class="input-group">
                        <span class="input-group-text bg-light">
                            <i class="bi bi-search"></i>
                        </span>
                        <input type="text" class="form-control" placeholder="Search documents..." id="searchInput">
                    </div>
                </div>
                <div class="col-md-3">
                    <select class="form-select" id="statusFilter">
                        <option value="">All Status</option>
                        <option value="Pending">Pending</option>
                        <option value="Approved">Approved</option>
                        <option value="Rejected">Rejected</option>
                        <option value="Revision">Revision</option>
                    </select>
                </div>
            </div>

            <!-- Documents Table -->
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Title</th>
                            <th>Uploaded On</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="documentsTable">
                        <!-- Documents will be loaded here via API -->
                        <tr>
                            <td colspan="4" class="text-center text-muted py-4">
                                <i class="bi bi-inbox me-2"></i>No documents yet. <a href="/Member/Upload">Upload your first document</a>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Empty State -->
    <div id="emptyState" class="text-center py-5" style="display: none;">
        <i class="bi bi-file-earmark" style="font-size: 3rem; color: #ccc;"></i>
        <p class="text-muted mt-3">No documents found</p>
    </div>
</div>

