@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container-fluid">
    <h2 class="mb-4 fw-bold">
        <i class="bi bi-speedometer2 me-2"></i>Admin Dashboard
    </h2>

    <!-- Stats Row -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card shadow-sm border-0">
                <div class="card-body text-center">
                    <i class="bi bi-people" style="font-size: 2rem; color: #007bff;"></i>
                    <h5 class="mt-3">Total Users</h5>
                    <h2 class="text-primary">0</h2>
                    <small class="text-muted">Active users</small>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm border-0">
                <div class="card-body text-center">
                    <i class="bi bi-file-earmark" style="font-size: 2rem; color: #28a745;"></i>
                    <h5 class="mt-3">Total Documents</h5>
                    <h2 class="text-success">0</h2>
                    <small class="text-muted">Across all users</small>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm border-0">
                <div class="card-body text-center">
                    <i class="bi bi-hourglass-split" style="font-size: 2rem; color: #ffc107;"></i>
                    <h5 class="mt-3">Pending</h5>
                    <h2 class="text-warning">0</h2>
                    <small class="text-muted">Awaiting approval</small>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm border-0">
                <div class="card-body text-center">
                    <i class="bi bi-check-circle" style="font-size: 2rem; color: #6f42c1;"></i>
                    <h5 class="mt-3">Approved</h5>
                    <h2 class="text-info">0</h2>
                    <small class="text-muted">Completed</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Admin Actions -->
    <div class="row">
        <div class="col-md-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">
                        <i class="bi bi-gear me-2"></i>Quick Actions
                    </h5>
                </div>
                <div class="card-body">
                    <a href="/Admin/Users" class="btn btn-outline-primary w-100 mb-2">
                        <i class="bi bi-people me-2"></i>Manage Users
                    </a>
                    <a href="/Admin/Reports" class="btn btn-outline-primary w-100 mb-2">
                        <i class="bi bi-graph-up me-2"></i>View Reports
                    </a>
                    <a href="/Admin/Settings" class="btn btn-outline-primary w-100">
                        <i class="bi bi-sliders me-2"></i>System Settings
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0">
                        <i class="bi bi-info-circle me-2"></i>System Status
                    </h5>
                </div>
                <div class="card-body">
                    <p class="mb-2">
                        <i class="bi bi-check-circle text-success me-2"></i>
                        <strong>Database:</strong> Connected
                    </p>
                    <p class="mb-2">
                        <i class="bi bi-check-circle text-success me-2"></i>
                        <strong>API Server:</strong> Running
                    </p>
                    <p class="mb-0">
                        <i class="bi bi-check-circle text-success me-2"></i>
                        <strong>File Storage:</strong> Available
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>