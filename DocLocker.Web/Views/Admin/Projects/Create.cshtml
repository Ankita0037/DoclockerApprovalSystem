@using DocLocker.Web.Models
@model AdminProjectFormViewModel

@{
    ViewData["Title"] = "Create Project";
}

<div class="container-fluid mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-body">
            <form asp-action="CreateProject" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                <div class="mb-3">
                    <label class="form-label">Project Name</label>
                    <input class="form-control" name="Name" value="@Model.Name" required data-val="true" data-val-required="Project name is required." />
                    <span class="text-danger small" data-valmsg-for="Name" data-valmsg-replace="true"></span>
                </div>
                <div class="mb-3">
                    <label class="form-label">Manager</label>
                    <select class="form-select" name="ManagerId" required data-val="true" data-val-required="Manager is required.">
                        <option value="">Select manager</option>
                        @foreach (var manager in Model.Managers)
                        {
                            <option value="@manager.UserId" selected="@(Model.ManagerId == manager.UserId)">@manager.Name</option>
                        }
                    </select>
                    <span class="text-danger small" data-valmsg-for="ManagerId" data-valmsg-replace="true"></span>
                </div>
                <div class="d-flex gap-2">
                    <a class="btn btn-outline-secondary" asp-action="Projects">Cancel</a>
                    <button type="submit" class="btn btn-primary">Create</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
