@using DocLocker.Web.Models
@model AdminProjectsViewModel

@{
    ViewData["Title"] = "Projects";
}

<div class="container-fluid">
    <h2 class="mb-4 fw-bold">
        <i class="bi bi-folder2-open me-2"></i>Projects
    </h2>
    <p class="text-muted mb-0">Manage project portfolios and document workflows.</p>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger mt-3" role="alert">
            @TempData["Error"]
        </div>
    }
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success mt-3" role="alert">
            @TempData["Success"]
        </div>
    }
</div>

<div class="container-fluid mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white">
            <div class="row align-items-center">
                <div class="col">
                    <h5 class="mb-0">
                        <i class="bi bi-list me-2"></i>Project List
                    </h5>
                </div>
                <div class="col-auto">
                    <span class="badge bg-light text-dark">@Model.Projects.Count Projects</span>
                </div>
                <div class="col-auto">
                    <a class="btn btn-light btn-sm" asp-action="CreateProject">
                        <i class="bi bi-plus-circle me-1"></i>Create Project
                    </a>
                </div>
            </div>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Project</th>
                            <th>Manager</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Projects.Count == 0)
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted py-4">
                                    <i class="bi bi-inbox me-2"></i>No projects found.
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var project in Model.Projects)
                            {
                                <tr>
                                    <td>@project.Name</td>
                                    <td>@project.ManagerName</td>
                                    <td>@project.Status</td>
                                    <td>
                                        <a class="btn btn-sm btn-outline-primary" asp-action="EditProject" asp-route-projectId="@project.ProjectId">Edit</a>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
