@using DocLocker.Core.Models
@model IReadOnlyList<UserSummaryDTO>

@{
    ViewData["Title"] = "Manage Users";
}

<div class="container-fluid">
    <h2 class="mb-4 fw-bold">
        <i class="bi bi-people me-2"></i>Manage Users
    </h2>

    <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white">
            <div class="row align-items-center">
                <div class="col">
                    <h5 class="mb-0">
                        <i class="bi bi-list me-2"></i>User List
                    </h5>
                </div>
                <div class="col-auto">
                    <span class="badge bg-light text-dark">@Model.Count Users</span>
                </div>
                <div class="col-auto">
                    <button class="btn btn-light btn-sm" data-bs-toggle="modal" data-bs-target="#createUserModal">
                        <i class="bi bi-person-plus me-1"></i>Create User
                    </button>
                </div>
            </div>
        </div>
        <div class="card-body">

            <!-- Filter and Search -->
            <div class="row mb-4">
                <div class="col-md-6">
                    <div class="input-group">
                        <span class="input-group-text bg-light">
                            <i class="bi bi-search"></i>
                        </span>
                        <input type="text" class="form-control" placeholder="Search users..." id="searchInput">
                    </div>
                </div>
                <div class="col-md-3">
                    <select class="form-select" id="roleFilter">
                        <option value="">All Roles</option>
                        <option value="Admin">Admin</option>
                        <option value="Member">Member</option>
                        <option value="Manager">Manager</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <select class="form-select" id="statusFilter">
                        <option value="">All Status</option>
                        <option value="active">Active</option>
                        <option value="inactive">Inactive</option>
                    </select>
                </div>
            </div>

            <!-- Users Table -->
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Role</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="usersTable">
                        @if (Model.Count == 0)
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted py-4">
                                    <i class="bi bi-inbox me-2"></i>No users found.
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var user in Model)
                            {
                                <tr data-role="@user.RoleName" data-status="@(user.IsActive ? "active" : "inactive")" data-name="@user.Name" data-email="@user.Email">
                                    <td>@user.Name</td>
                                    <td>@user.Email</td>
                                    <td>@user.RoleName</td>
                                    <td>
                                        @if (user.IsActive)
                                        {
                                            <span class="badge bg-success">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Inactive</span>
                                        }
                                    </td>
                                    <td>
                                        <button type="button" class="btn btn-sm btn-outline-primary me-2" data-bs-toggle="modal" data-bs-target="#editUserModal"
                                                data-userid="@user.UserId" data-name="@user.Name" data-phone="@user.PhoneNumber" data-rolename="@user.RoleName" data-roleid="@(user.RoleName == "Admin" ? 1 : user.RoleName == "Manager" ? 2 : 3)" data-allowusermanagement="@user.AllowUserManagement">
                                            Edit
                                        </button>
                                        <form asp-action="ToggleActivation" asp-route-userId="@user.UserId" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm @(user.IsActive ? "btn-outline-danger" : "btn-outline-success")">
                                                @(user.IsActive ? "Deactivate" : "Activate")
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                        <tr id="noUsersMatchRow" class="d-none">
                            <td colspan="5" class="text-center text-muted py-4">
                                <i class="bi bi-search me-2"></i>No users match the selected filters.
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
            <div class="d-flex justify-content-between align-items-center mt-3" id="paginationContainer">
                <button class="btn btn-outline-secondary btn-sm" id="prevPage" type="button">Previous</button>
                <span class="small text-muted" id="pageInfo"></span>
                <button class="btn btn-outline-secondary btn-sm" id="nextPage" type="button">Next</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="createUserModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Create User</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="CreateUser" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                    <div class="mb-3">
                        <label class="form-label">Full Name</label>
                        <input class="form-control" name="FullName" minlength="3" required data-val="true" data-val-required="Full name is required." data-val-length="Full name must be at least 3 characters." data-val-length-min="3" />
                        <span class="text-danger small" data-valmsg-for="FullName" data-valmsg-replace="true"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input class="form-control" type="email" name="Email" required data-val="true" data-val-required="Email is required." data-val-email="Enter a valid email address." />
                        <span class="text-danger small" data-valmsg-for="Email" data-valmsg-replace="true"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Phone Number</label>
                        <input class="form-control" name="PhoneNumber" pattern="^[0-9]{10}$" required data-val="true" data-val-required="Phone number is required." data-val-regex="Enter a 10-digit phone number." data-val-regex-pattern="^[0-9]{10}$" />
                        <span class="text-danger small" data-valmsg-for="PhoneNumber" data-valmsg-replace="true"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Password</label>
                        <input class="form-control" type="password" name="Password" required data-val="true" data-val-required="Password is required." data-val-regex="Use at least 8 characters with uppercase, lowercase, number, and special character." data-val-regex-pattern="^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[^a-zA-Z0-9]).{8,}$"
                               title="At least 8 characters with uppercase, lowercase, number, and special character" />
                        <span class="text-danger small" data-valmsg-for="Password" data-valmsg-replace="true"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Role</label>
                        <select class="form-select" id="createRoleId" name="RoleId" required data-val="true" data-val-required="Role is required.">
                            <option value="1">Admin</option>
                            <option value="2">Manager</option>
                            <option value="3" selected>Member</option>
                        </select>
                        <span class="text-danger small" data-valmsg-for="RoleId" data-valmsg-replace="true"></span>
                    </div>
                    <div class="mb-3" id="createUserManagementSection" style="display: none;">
                        <label class="form-label">User Management Access</label>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="createAllowUserManagement" name="AllowUserManagement" value="true" checked>
                            <label class="form-check-label" for="createAllowUserManagement">
                                Allow access to user management
                            </label>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Create</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="editUserModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Edit User</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="UpdateUser" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" id="editUserId" name="userId" />
                <div class="modal-body">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                    <div class="mb-3">
                        <label class="form-label">Full Name</label>
                        <input class="form-control" id="editFullName" name="FullName" minlength="3" required data-val="true" data-val-required="Full name is required." data-val-length="Full name must be at least 3 characters." data-val-length-min="3" />
                        <span class="text-danger small" data-valmsg-for="FullName" data-valmsg-replace="true"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Phone Number</label>
                        <input class="form-control" id="editPhoneNumber" name="PhoneNumber" pattern="^[0-9]{10}$" required data-val="true" data-val-required="Phone number is required." data-val-regex="Enter a 10-digit phone number." data-val-regex-pattern="^[0-9]{10}$" />
                        <span class="text-danger small" data-valmsg-for="PhoneNumber" data-valmsg-replace="true"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Role</label>
                        <select class="form-select" id="editRoleId" name="RoleId" required data-val="true" data-val-required="Role is required.">
                            <option value="1">Admin</option>
                            <option value="2">Manager</option>
                            <option value="3">Member</option>
                        </select>
                        <input type="hidden" id="editRoleIdHidden" name="RoleId" />
                        <span class="text-danger small" data-valmsg-for="RoleId" data-valmsg-replace="true"></span>
                    </div>
                    <div class="mb-3" id="editUserManagementSection" style="display: none;">
                        <label class="form-label">User Management Access</label>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="editAllowUserManagement" name="AllowUserManagement" value="true">
                            <label class="form-check-label" for="editAllowUserManagement">
                                Allow access to user management
                            </label>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const pageSize = 8;
        let currentPage = 1;
        let filteredRows = [];

        const searchInput = document.getElementById('searchInput');
        const roleFilter = document.getElementById('roleFilter');
        const statusFilter = document.getElementById('statusFilter');
        const previousButton = document.getElementById('prevPage');
        const nextButton = document.getElementById('nextPage');
        const pageInfo = document.getElementById('pageInfo');
        const paginationContainer = document.getElementById('paginationContainer');
        const noUsersMatchRow = document.getElementById('noUsersMatchRow');

        function getUserRows() {
            return Array.from(document.querySelectorAll('#usersTable tr[data-name][data-email][data-role][data-status]'));
        }

        function applyFilters() {
            const search = (searchInput?.value ?? '').trim().toLowerCase();
            const role = (roleFilter?.value ?? '').toLowerCase();
            const status = (statusFilter?.value ?? '').toLowerCase();

            filteredRows = getUserRows().filter(row => {
                const rowName = row.dataset.name?.toLowerCase() ?? '';
                const rowEmail = row.dataset.email?.toLowerCase() ?? '';
                const rowRole = row.dataset.role?.toLowerCase() ?? '';
                const rowStatus = row.dataset.status?.toLowerCase() ?? '';

                const matchesSearch = !search || rowName.includes(search) || rowEmail.includes(search);
                const matchesRole = !role || rowRole === role;
                const matchesStatus = !status || rowStatus === status;

                return matchesSearch && matchesRole && matchesStatus;
            });

            currentPage = 1;
            renderPage();
        }

        function renderPage() {
            const allRows = getUserRows();
            const totalPages = Math.max(1, Math.ceil(filteredRows.length / pageSize));
            currentPage = Math.min(currentPage, totalPages);

            allRows.forEach(row => row.style.display = 'none');

            const start = (currentPage - 1) * pageSize;
            const currentRows = filteredRows.slice(start, start + pageSize);
            currentRows.forEach(row => {
                row.style.display = '';
            });

            if (noUsersMatchRow) {
                noUsersMatchRow.classList.toggle('d-none', filteredRows.length > 0);
            }

            if (paginationContainer) {
                paginationContainer.classList.toggle('d-none', allRows.length <= pageSize && filteredRows.length === allRows.length);
            }

            if (pageInfo) {
                pageInfo.textContent = filteredRows.length === 0
                    ? 'No users to display'
                    : `Page ${currentPage} of ${totalPages} (${filteredRows.length} users)`;
            }

            if (previousButton) {
                previousButton.disabled = currentPage <= 1 || filteredRows.length === 0;
            }

            if (nextButton) {
                nextButton.disabled = currentPage >= totalPages || filteredRows.length === 0;
            }
        }

        searchInput?.addEventListener('input', applyFilters);
        roleFilter?.addEventListener('change', applyFilters);
        statusFilter?.addEventListener('change', applyFilters);

        previousButton?.addEventListener('click', function () {
            currentPage = Math.max(1, currentPage - 1);
            renderPage();
        });

        nextButton?.addEventListener('click', function () {
            const totalPages = Math.max(1, Math.ceil(filteredRows.length / pageSize));
            currentPage = Math.min(totalPages, currentPage + 1);
            renderPage();
        });

        const createRoleSelect = document.getElementById('createRoleId');
        const createUserManagementSection = document.getElementById('createUserManagementSection');
        const createAllowUserManagement = document.getElementById('createAllowUserManagement');

        function toggleCreateUserManagement() {
            const isAdminRole = createRoleSelect?.value === '1';
            if (!createUserManagementSection || !createAllowUserManagement) return;
            createUserManagementSection.style.display = isAdminRole ? '' : 'none';
            createAllowUserManagement.checked = isAdminRole;
        }

        createRoleSelect?.addEventListener('change', toggleCreateUserManagement);
        toggleCreateUserManagement();

        document.getElementById('editRoleId')?.addEventListener('change', function (event) {
            const roleSelect = event.target;
            const userManagementSection = document.getElementById('editUserManagementSection');
            const userManagementToggle = document.getElementById('editAllowUserManagement');
            const isAdminRole = roleSelect.value === '1';
            if (!userManagementSection || !userManagementToggle) return;
            userManagementSection.style.display = isAdminRole ? '' : 'none';
            userManagementToggle.checked = isAdminRole;
        });

        document.getElementById('editUserModal')?.addEventListener('show.bs.modal', function (event) {
            const button = event.relatedTarget;
            if (!button) return;
            const roleId = button.getAttribute('data-roleid') || '3';
            const roleName = button.getAttribute('data-rolename') || '';
            const allowUserManagement = button.getAttribute('data-allowusermanagement') || 'false';
            const roleSelect = document.getElementById('editRoleId');
            const roleHidden = document.getElementById('editRoleIdHidden');
            const userManagementSection = document.getElementById('editUserManagementSection');
            const userManagementToggle = document.getElementById('editAllowUserManagement');
            document.getElementById('editUserId').value = button.getAttribute('data-userid') || '';
            document.getElementById('editFullName').value = button.getAttribute('data-name') || '';
            document.getElementById('editPhoneNumber').value = button.getAttribute('data-phone') || '';
            roleSelect.value = roleId;
            roleHidden.value = roleId;
            const isAdmin = roleName.toLowerCase() === 'admin' || roleId === '1';
            roleSelect.disabled = isAdmin;
            if (userManagementSection && userManagementToggle) {
                userManagementSection.style.display = isAdmin ? '' : 'none';
                userManagementToggle.checked = allowUserManagement.toLowerCase() === 'true';
            }
        });

        applyFilters();
    </script>
}
