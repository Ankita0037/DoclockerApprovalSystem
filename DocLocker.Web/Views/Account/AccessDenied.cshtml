@{
    ViewData["Title"] = "Access Denied - DocLocker";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-7 col-lg-5">
            <div class="card auth-card text-center">
                <div class="card-body">
                    <i class="bi bi-shield-lock text-danger display-4 mb-3"></i>
                    <h1 class="auth-title">Access Denied</h1>
                    <p class="auth-subtitle">
                        Your current role does not have permission to open this page.
                    </p>
                    <a asp-controller="Account" asp-action="Login" class="btn btn-primary">
                        <i class="bi bi-box-arrow-in-right me-2"></i>Go to Login
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
